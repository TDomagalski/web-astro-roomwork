---
import { SEO } from 'astro-seo';
import { ClientRouter } from 'astro:transitions';
import { siteConfig } from '../data/siteConfig';
import Navbar from '../components/sections/Navbar.astro';
import Footer from '../components/sections/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
}

const { title, description, canonical, ogImage } = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${siteConfig.url}/#business`,
  name: siteConfig.name,
  url: siteConfig.url,
  telephone: siteConfig.phone,
  email: siteConfig.email,
  image: `${siteConfig.url}${siteConfig.defaultOgImage}`,
  priceRange: siteConfig.priceRange,
  address: {
    '@type': 'PostalAddress',
    streetAddress: siteConfig.address.street,
    addressLocality: siteConfig.address.city,
    postalCode: siteConfig.address.zip,
    addressCountry: siteConfig.address.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: siteConfig.geo.lat,
    longitude: siteConfig.geo.lng,
  },
  openingHoursSpecification: siteConfig.openingHours.map((spec) => ({
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: spec.days,
    opens: spec.opens,
    closes: spec.closes,
  })),
};
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content={siteConfig.themeColor} media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0E1812" media="(prefers-color-scheme: dark)" />
    <meta name="format-detection" content="telephone=no" />
    <script is:inline>
      (function () {
        function applyTheme() {
          try {
            var pref = localStorage.getItem('theme-pref') || 'auto';
            var resolved =
              pref === 'dark' ||
              (pref === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches)
                ? 'dark'
                : 'light';
            document.documentElement.dataset.theme = resolved;
            document.documentElement.dataset.themePref = pref;
          } catch (e) {
            document.documentElement.dataset.theme = 'light';
            document.documentElement.dataset.themePref = 'auto';
          }
        }
        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <SEO
      title={title}
      description={description}
      canonical={canonical ?? Astro.url.href}
      openGraph={{
        basic: {
          title,
          type: 'website',
          image: ogImage ?? `${siteConfig.url}${siteConfig.defaultOgImage}`,
          url: canonical ?? Astro.url.href,
        },
        optional: {
          description,
          siteName: siteConfig.name,
          locale: 'pl_PL',
        },
      }}
      twitter={{ card: 'summary_large_image' }}
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <ClientRouter />
  </head>
  <body>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:p-4 focus:bg-surface focus:text-primary"
    >
      Przejdź do treści
    </a>
    <slot name="header"><Navbar /></slot>
    <main id="main-content">
      <slot />
    </main>
    <slot name="footer"><Footer /></slot>
  </body>
</html>
