---

<section aria-labelledby="amenities-heading" class="bg-background py-16 lg:py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="mb-12 lg:mb-16">
      <span
        class="border-border bg-surface text-primary inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-medium tracking-wider uppercase"
      >
        <span aria-hidden="true" class="bg-primary h-1.5 w-1.5 rounded-full"></span>
        Wyposażenie i udogodnienia
      </span>
      <h2
        id="amenities-heading"
        class="font-heading text-text text-headline leading-headline mt-5 font-bold"
      >
        Wszystko czego potrzebuje Twoja ekipa
      </h2>
      <p class="text-text-muted leading-body mt-3 max-w-xl text-base">
        Zadbaliśmy o każdy detal, żeby Twoi pracownicy mogli odpocząć po ciężkim dniu. Pełne
        wyposażenie bez ukrytych kosztów.
      </p>
    </div>

    <ul class="grid grid-cols-2 gap-4 md:grid-cols-3 xl:grid-cols-4" aria-label="Lista udogodnień">
      {
        amenities.map((item) => (
          <li class="border-border bg-surface group hover:border-primary flex flex-col gap-4 rounded-2xl border p-5 transition-[border-color,box-shadow] duration-200 hover:shadow-[0_8px_24px_-8px_var(--glow-action)]">
            <div class="bg-primary flex h-12 w-12 shrink-0 items-center justify-center rounded-full shadow-sm">
              <svg
                viewBox="0 0 24 24"
                fill={'fill' in item && item.fill ? 'currentColor' : 'none'}
                stroke={'fill' in item && item.fill ? 'none' : 'currentColor'}
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-on-primary h-6 w-6"
                aria-hidden="true"
                set:html={item.icon}
              />
            </div>
            <div>
              <p class="text-text text-sm font-semibold">{item.title}</p>
              <p class="text-text-muted leading-body mt-1 text-xs">{item.description}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>
