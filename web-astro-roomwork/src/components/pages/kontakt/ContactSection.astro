---
import { siteConfig } from '../../../data/siteConfig';
import { formatDays } from '../../../utils/openingHours';

const { phone: phoneRaw, phoneFormatted } = siteConfig;
---

<section aria-labelledby="contact-heading" class="bg-background py-16 lg:py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <!-- Nagłówek sekcji -->
    <div class="mb-12 lg:mb-16">
      <span
        class="border-border bg-surface text-primary inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-medium tracking-wider uppercase"
      >
        <span aria-hidden="true" class="bg-primary h-1.5 w-1.5 rounded-full"></span>
        Dane kontaktowe
      </span>
      <h2
        id="contact-heading"
        class="font-heading text-text text-headline leading-headline mt-5 font-bold"
      >
        Napisz lub zadzwoń — jesteśmy tu dla&nbsp;Ciebie
      </h2>
      <p class="text-text-muted leading-body mt-3 max-w-lg text-base">
        Dobierzemy wolne miejsca do Twoich potrzeb. Ekipy budowlane, delegacje, pracownicy sezonowi
        — każde zamówienie traktujemy indywidualnie.
      </p>
    </div>

    <!-- Trzy karty kontaktowe -->
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <!-- Telefon (wyróżniona) -->
      <a
        href={`tel:${phoneRaw}`}
        class="group border-border bg-surface hover:border-primary relative flex flex-col overflow-hidden rounded-2xl border p-6 transition-[border-color,box-shadow] duration-200 hover:shadow-[0_8px_32px_-8px_var(--glow-action)] sm:col-span-2 lg:col-span-1"
        aria-label={`Zadzwoń pod numer ${phoneFormatted}`}
      >
        <span aria-hidden="true" class="bg-primary absolute inset-x-0 top-0 h-0.5"></span>

        <div class="mb-4 flex items-center gap-3">
          <div
            class="bg-primary/10 flex h-10 w-10 shrink-0 items-center justify-center rounded-full"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-primary h-5 w-5"
              aria-hidden="true"
            >
              <path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
              ></path>
            </svg>
          </div>
          <p class="text-label tracking-label text-text-muted font-medium uppercase">Telefon</p>
        </div>
        <p class="font-heading text-text mt-2 text-3xl font-bold tracking-tight sm:text-4xl">
          {phoneFormatted}
        </p>
        <p class="text-text-muted mt-1.5 text-sm">Odbieramy Pn–Nd, przez cały dzień</p>

        <span
          class="bg-primary text-on-primary group-hover:bg-secondary mt-6 inline-flex w-fit items-center gap-2 rounded-full px-5 py-2.5 text-sm font-semibold transition-[background-color,transform] duration-200 group-hover:-translate-y-px"
        >
          Zadzwoń teraz
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-3.5 w-3.5"
            aria-hidden="true"
          >
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </span>
      </a>

      <!-- Email -->
      <a
        href={`mailto:${siteConfig.email}`}
        class="group border-border bg-surface hover:border-primary flex flex-col rounded-2xl border p-6 transition-[border-color,box-shadow] duration-200 hover:shadow-[0_8px_32px_-8px_var(--glow-action)]"
        aria-label={`Wyślij e-mail na adres ${siteConfig.email}`}
      >
        <div class="mb-4 flex items-center gap-3">
          <div
            class="bg-primary/10 flex h-10 w-10 shrink-0 items-center justify-center rounded-full"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-primary h-5 w-5"
              aria-hidden="true"
            >
              <rect x="2" y="4" width="20" height="16" rx="2"></rect>
              <path d="m22 7-10 6L2 7"></path>
            </svg>
          </div>
          <p class="text-label tracking-label text-text-muted font-medium uppercase">E-mail</p>
        </div>
        <p
          class="font-heading text-text group-hover:text-primary mt-2 text-xl font-bold break-all transition-colors duration-200"
        >
          {siteConfig.email}
        </p>
        <p class="text-text-muted leading-body mt-1.5 text-sm">
          Odpisujemy najszybciej jak to możliwe
        </p>

        <span
          class="text-primary mt-auto inline-flex items-center gap-1.5 pt-5 text-sm font-semibold"
        >
          Napisz do nas
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-3.5 w-3.5 transition-transform duration-200 group-hover:translate-x-0.5"
            aria-hidden="true"
          >
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </span>
      </a>

      <!-- Adres + godziny -->
      <div class="border-border bg-surface flex flex-col gap-0 rounded-2xl border p-6">
        <div class="mb-4 flex items-center gap-3">
          <div
            class="bg-primary/10 flex h-10 w-10 shrink-0 items-center justify-center rounded-full"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-primary h-5 w-5"
              aria-hidden="true"
            >
              <path d="M20 10c0 7-8 13-8 13s-8-6-8-13a8 8 0 0 1 16 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
          </div>
          <p class="text-label tracking-label text-text-muted font-medium uppercase">Adres</p>
        </div>
        <p class="text-text mt-2 text-base leading-snug font-medium">
          {siteConfig.address.street}<br />{siteConfig.address.zip}&nbsp;{siteConfig.address.city}
        </p>
        <a
          href={siteConfig.social.googleMaps}
          target="_blank"
          rel="noopener noreferrer"
          class="text-primary hover:text-secondary mt-2 inline-flex items-center gap-1 text-sm font-medium transition-colors duration-200"
          aria-label="Otwórz lokalizację na Google Maps"
        >
          Pokaż na mapie
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-3 w-3"
            aria-hidden="true"
          >
            <path d="M7 17 17 7"></path>
            <path d="M7 7h10v10"></path>
          </svg>
        </a>

        <div class="border-border mt-6 border-t pt-6">
          <div class="mb-3 flex items-center gap-3">
            <div
              class="bg-primary/10 flex h-10 w-10 shrink-0 items-center justify-center rounded-full"
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-primary h-5 w-5"
                aria-hidden="true"
              >
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
            </div>
            <p class="text-label tracking-label text-text-muted font-medium uppercase">
              Godziny odwiedzin
            </p>
          </div>
          <div class="mt-2 space-y-1.5">
            {
              siteConfig.openingHours.map((spec) => (
                <div class="flex items-center justify-between gap-4">
                  <span class="text-text-muted text-sm">{formatDays(spec.days)}</span>
                  <span class="text-text text-sm font-medium tabular-nums">
                    {spec.opens}–{spec.closes}
                  </span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <!-- Znajdź nas online -->
    <div class="mt-8">
      <p class="text-label tracking-label text-text-muted mb-4 font-medium uppercase">
        Znajdź nas online
      </p>
      <div class="grid gap-4 sm:grid-cols-2">
        <!-- Google Wizytówka -->
        <a
          href={siteConfig.social.google}
          target="_blank"
          rel="noopener noreferrer"
          class="group border-border bg-surface hover:border-primary flex items-center gap-4 rounded-2xl border px-6 py-5 transition-[border-color,box-shadow] duration-200 hover:shadow-[0_8px_24px_-8px_var(--glow-action)]"
          aria-label="Otwórz profil RoomWork na Google"
        >
          <svg viewBox="0 0 24 24" class="h-8 w-8 shrink-0" aria-hidden="true">
            <path
              fill="#4285F4"
              d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
            ></path>
            <path
              fill="#34A853"
              d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
            ></path>
            <path
              fill="#FBBC05"
              d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"
            ></path>
            <path
              fill="#EA4335"
              d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
            ></path>
          </svg>
          <div class="min-w-0 flex-1">
            <p class="text-text font-semibold">Google Wizytówka</p>
            <p class="text-text-muted mt-0.5 text-sm">Opinie i szczegóły o obiekcie</p>
          </div>
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-text-muted group-hover:text-primary h-4 w-4 shrink-0 transition-colors duration-200"
            aria-hidden="true"
          >
            <path d="M7 17 17 7"></path>
            <path d="M7 7h10v10"></path>
          </svg>
        </a>

        <!-- Google Maps -->
        <a
          href={siteConfig.social.googleMaps}
          target="_blank"
          rel="noopener noreferrer"
          class="group border-border bg-surface hover:border-primary flex items-center gap-4 rounded-2xl border px-6 py-5 transition-[border-color,box-shadow] duration-200 hover:shadow-[0_8px_24px_-8px_var(--glow-action)]"
          aria-label="Otwórz RoomWork na Google Maps"
        >
          <div class="bg-primary/10 flex h-8 w-8 shrink-0 items-center justify-center rounded-full">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-primary h-5 w-5"
              aria-hidden="true"
            >
              <path d="M20 10c0 7-8 13-8 13s-8-6-8-13a8 8 0 0 1 16 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
          </div>
          <div class="min-w-0 flex-1">
            <p class="text-text font-semibold">Google Maps</p>
            <p class="text-text-muted mt-0.5 text-sm">Nawigacja i dojazd do obiektu</p>
          </div>
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-text-muted group-hover:text-primary h-4 w-4 shrink-0 transition-colors duration-200"
            aria-hidden="true"
          >
            <path d="M7 17 17 7"></path>
            <path d="M7 7h10v10"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
