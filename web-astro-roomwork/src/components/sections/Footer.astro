---
import { siteConfig } from '../../data/siteConfig';
import { navLinks } from '../../data/nav';
import { formatDays } from '../../utils/openingHours';

const { phone: phoneRaw, phoneFormatted } = siteConfig;

const fullAddress = `${siteConfig.address.street}, ${siteConfig.address.zip} ${siteConfig.address.city}`;

const year = new Date().getFullYear();
---

<footer class="bg-elevated text-on-elevated border-t-primary relative border-t-2">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,var(--glow-primary-soft),transparent_55%)]"
  >
  </div>

  <div class="relative mx-auto max-w-7xl px-4 pt-14 pb-8 sm:px-6 lg:px-8 lg:pt-20">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-12 lg:gap-8">
      <div class="min-w-0 lg:col-span-4">
        <a
          href="/"
          class="font-heading text-on-elevated hover:text-primary inline-flex items-baseline text-2xl font-semibold tracking-tight transition-colors"
          aria-label="RoomWork — strona główna"
        >
          <span>RoomWork</span>
          <span aria-hidden="true" class="text-primary">.</span>
        </a>
        <p class="text-on-elevated/70 mt-4 max-w-sm text-sm leading-relaxed">
          Komfortowe kwatery pracownicze w Słomnikach. Profesjonalne zakwaterowanie dla zespołów:
          pełne wyposażenie, transparentne warunki, faktura VAT.
        </p>

        <div class="border-on-elevated/10 mt-6 border-t pt-5">
          <p class="text-label tracking-label text-on-elevated/50 font-medium uppercase">
            Dane rejestrowe
          </p>
          <p class="text-on-elevated/80 mt-2 text-sm font-medium">Family Party Sp. z o.o.</p>
          <p class="text-on-elevated/60 mt-0.5 text-xs">
            ul. Krakowska 62d, 32-090 Słomniki
          </p>
          <div class="mt-3 flex flex-col gap-2">
            <div class="flex items-center gap-2">
              <span class="text-on-elevated/60 text-xs">
                NIP: <span class="text-on-elevated/80 font-medium">6821777738</span>
              </span>
              <button
                type="button"
                data-copy="6821777738"
                data-label="NIP"
                aria-label="Kopiuj NIP"
                class="copy-btn text-on-elevated/40 hover:text-primary flex h-5 w-5 shrink-0 items-center justify-center rounded transition-colors duration-150"
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5" aria-hidden="true">
                  <rect x="9" y="9" width="13" height="13" rx="2"></rect>
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                </svg>
              </button>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-on-elevated/60 text-xs">
                REGON: <span class="text-on-elevated/80 font-medium">381101585</span>
              </span>
              <button
                type="button"
                data-copy="381101585"
                data-label="REGON"
                aria-label="Kopiuj REGON"
                class="copy-btn text-on-elevated/40 hover:text-primary flex h-5 w-5 shrink-0 items-center justify-center rounded transition-colors duration-150"
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5" aria-hidden="true">
                  <rect x="9" y="9" width="13" height="13" rx="2"></rect>
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                </svg>
              </button>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-on-elevated/60 text-xs">
                KRS: <span class="text-on-elevated/80 font-medium">0000746071</span>
              </span>
              <button
                type="button"
                data-copy="0000746071"
                data-label="KRS"
                aria-label="Kopiuj KRS"
                class="copy-btn text-on-elevated/40 hover:text-primary flex h-5 w-5 shrink-0 items-center justify-center rounded transition-colors duration-150"
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5" aria-hidden="true">
                  <rect x="9" y="9" width="13" height="13" rx="2"></rect>
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                </svg>
              </button>
            </div>
          </div>
        </div>
      </div>

      <nav aria-labelledby="footer-nav-heading" class="min-w-0 lg:col-span-2">
        <h2
          id="footer-nav-heading"
          class="text-label tracking-label text-on-elevated font-medium uppercase"
        >
          Nawigacja
        </h2>
        <ul class="mt-4 flex flex-col gap-3 text-sm">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-on-elevated/70 hover:text-primary inline-flex transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="min-w-0 lg:col-span-3">
        <h2 class="text-label tracking-label text-on-elevated font-medium uppercase">Kontakt</h2>
        <ul class="mt-4 flex flex-col gap-3 text-sm">
          <li>
            <a
              href={siteConfig.social.googleMaps}
              target="_blank"
              rel="noopener noreferrer"
              class="group text-on-elevated/70 hover:text-primary inline-flex items-start gap-3 transition-colors"
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-primary mt-0.5 h-4 w-4 shrink-0"
                aria-hidden="true"
              >
                <path d="M20 10c0 7-8 13-8 13s-8-6-8-13a8 8 0 0 1 16 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
              <span>
                {siteConfig.address.street}<br />
                {siteConfig.address.zip}
                {siteConfig.address.city}
              </span>
            </a>
          </li>
          <li>
            <a
              href={`tel:${phoneRaw}`}
              class="text-on-elevated/70 hover:text-primary inline-flex items-center gap-3 transition-colors"
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-primary h-4 w-4 shrink-0"
                aria-hidden="true"
              >
                <path
                  d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                ></path>
              </svg>
              <span>{phoneFormatted}</span>
            </a>
          </li>
          <li>
            <a
              href={`mailto:${siteConfig.email}`}
              class="text-on-elevated/70 hover:text-primary inline-flex items-center gap-3 transition-colors"
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-primary h-4 w-4 shrink-0"
                aria-hidden="true"
              >
                <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                <path d="m22 7-10 6L2 7"></path>
              </svg>
              <span class="break-all">{siteConfig.email}</span>
            </a>
          </li>
          <li class="text-on-elevated/70 flex items-start gap-3">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-primary mt-0.5 h-4 w-4 shrink-0"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
            <span>
              {
                siteConfig.openingHours.map((spec) => (
                  <span class="block">
                    {formatDays(spec.days)}: {spec.opens}–{spec.closes}
                  </span>
                ))
              }
            </span>
          </li>
        </ul>
      </div>

      <div class="min-w-0 lg:col-span-3">
        <h2 class="text-label tracking-label text-on-elevated font-medium uppercase">
          Lokalizacja
        </h2>
        <div id="map-shell" class="ring-on-elevated/15 mt-4 overflow-hidden rounded-2xl ring-1">
          <button
            id="map-facade"
            type="button"
            data-src={siteConfig.mapsEmbed}
            aria-label={`Załaduj mapę Google: ${fullAddress}`}
            class="group focus-visible:ring-primary block w-full cursor-pointer text-left transition-shadow duration-200 hover:shadow-[0_20px_40px_-20px_var(--glow-action)] focus-visible:ring-2 focus-visible:outline-none focus-visible:ring-inset"
          >
            <div
              class="relative aspect-4/3 bg-[linear-gradient(135deg,var(--glow-nav),var(--glow-primary-soft))]"
            >
              <div
                aria-hidden="true"
                class="absolute inset-0 bg-[linear-gradient(rgb(255_255_255/0.06)_1px,transparent_1px),linear-gradient(90deg,rgb(255_255_255/0.06)_1px,transparent_1px)] bg-size-[24px_24px]"
              >
              </div>
              <div
                aria-hidden="true"
                class="bg-primary/20 absolute top-1/2 left-1/2 h-24 w-24 -translate-x-1/2 -translate-y-1/2 rounded-full blur-2xl"
              >
              </div>
              <div
                class="absolute top-1/2 left-1/2 flex -translate-x-1/2 -translate-y-1/2 flex-col items-center gap-2 transition-transform duration-300 ease-out group-hover:translate-y-[-60%]"
              >
                <span
                  class="bg-primary text-on-primary flex h-12 w-12 items-center justify-center rounded-full shadow-[0_10px_30px_-10px_var(--glow-pin)]"
                >
                  <svg viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6" aria-hidden="true">
                    <path
                      d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5z"
                    ></path>
                  </svg>
                </span>
                <span
                  aria-hidden="true"
                  class="bg-elevated/80 text-on-elevated/60 rounded-full px-2.5 py-0.5 text-xs opacity-0 backdrop-blur-sm transition-opacity duration-200 group-hover:opacity-100"
                >
                  kliknij, aby załadować
                </span>
              </div>
            </div>
          </button>
        </div>
      </div>
    </div>

    <div
      class="border-on-elevated/10 text-on-elevated/60 mt-12 flex flex-col gap-4 border-t pt-6 text-xs sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {year} {siteConfig.name}. Wszystkie prawa zastrzeżone.</p>
      <ul class="flex flex-wrap items-center gap-x-5 gap-y-2">
        <li>
          <a href="/polityka-prywatnosci" class="hover:text-primary transition-colors">
            Polityka prywatności
          </a>
        </li>
        <li>
          <a href="/regulamin" class="hover:text-primary transition-colors"> Regulamin </a>
        </li>
      </ul>
    </div>
  </div>
</footer>

<script>
  function initMapFacade(): void {
    const shell = document.getElementById('map-shell');
    const facade = document.getElementById('map-facade') as HTMLButtonElement | null;
    if (!shell || !facade) return;

    facade.addEventListener(
      'click',
      () => {
        const src = facade.dataset.src;
        if (!src) return;

        const iframe = document.createElement('iframe');
        iframe.src = src;
        iframe.title = 'Mapa Google Maps — RoomWork, ul. Krakowska 62d, Słomniki';
        iframe.setAttribute('allowfullscreen', '');
        iframe.setAttribute('referrerpolicy', 'no-referrer-when-downgrade');
        iframe.style.cssText = 'border:0;display:block;width:100%;aspect-ratio:4/3;';

        shell.innerHTML = '';
        shell.appendChild(iframe);
      },
      { once: true }
    );
  }

  document.addEventListener('astro:page-load', initMapFacade);

  function initCopyButtons(): void {
    document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const value = btn.dataset.copy;
        if (!value) return;

        try {
          await navigator.clipboard.writeText(value);
        } catch {
          return;
        }

        const original = btn.innerHTML;
        btn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
        btn.classList.add('text-primary');
        btn.setAttribute('aria-label', `Skopiowano ${btn.dataset.label ?? ''}`);

        setTimeout(() => {
          btn.innerHTML = original;
          btn.classList.remove('text-primary');
          btn.setAttribute('aria-label', `Kopiuj ${btn.dataset.label ?? ''}`);
        }, 2000);
      });
    });
  }

  document.addEventListener('astro:page-load', initCopyButtons);
</script>
