---
import { siteConfig } from '../../data/siteConfig';

const phoneFormatted = '690 328 659';
const phoneRaw = siteConfig.phone;

const dayMap: Record<string, string> = {
  Mo: 'Pn',
  Tu: 'Wt',
  We: 'Śr',
  Th: 'Cz',
  Fr: 'Pt',
  Sa: 'So',
  Su: 'Nd',
};

const formatDays = (days: readonly string[]): string => {
  if (days.length === 1) return dayMap[days[0]] ?? days[0];
  const first = dayMap[days[0]] ?? days[0];
  const last = dayMap[days[days.length - 1]] ?? days[days.length - 1];
  return `${first}–${last}`;
};

const fullAddress = `${siteConfig.address.street}, ${siteConfig.address.zip} ${siteConfig.address.city}`;
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(fullAddress)}`;
---

<section aria-labelledby="contact-heading" class="bg-background py-16 lg:py-24">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-14 lg:grid-cols-2 lg:gap-0">

      <!-- Lewa: nagłówek + telefon -->
      <div class="flex flex-col justify-center lg:pr-14">
        <span
          class="border-border bg-surface text-primary inline-flex w-fit items-center gap-2 rounded-full border px-3 py-1 text-xs font-medium uppercase tracking-wider"
        >
          <span aria-hidden="true" class="bg-primary h-1.5 w-1.5 rounded-full"></span>
          Dane kontaktowe
        </span>

        <h2
          id="contact-heading"
          class="font-heading text-text mt-5 text-headline leading-headline font-bold"
        >
          Zadzwoń lub napisz
        </h2>

        <p class="text-text-muted mt-4 max-w-sm text-base leading-body">
          Odpowiadamy tego samego dnia. Chętnie dobierzemy pokoje do potrzeb Twojej firmy i ekipy.
        </p>

        <a
          href={`tel:${phoneRaw}`}
          class="group mt-8 inline-flex items-center gap-4 self-start"
          aria-label={`Zadzwoń pod numer ${phoneFormatted}`}
        >
          <span
            class="bg-primary text-on-primary group-hover:bg-secondary flex h-14 w-14 shrink-0 items-center justify-center rounded-full shadow-[0_8px_20px_-8px_var(--glow-action)] transition-colors duration-200"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-6 w-6"
              aria-hidden="true"
            >
              <path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
              ></path>
            </svg>
          </span>
          <div>
            <p class="text-label tracking-label text-text-muted font-medium uppercase">Zadzwoń</p>
            <p
              class="font-heading text-text group-hover:text-primary mt-0.5 text-2xl font-bold tracking-tight transition-colors duration-200"
            >
              {phoneFormatted}
            </p>
          </div>
        </a>
      </div>

      <!-- Prawa: kontakt i wizytówka -->
      <div class="border-border flex flex-col gap-6 border-t pt-14 lg:border-t-0 lg:border-l lg:pl-14 lg:pt-0">

        <!-- Email -->
        <a
          href={`mailto:${siteConfig.email}`}
          class="group flex items-center gap-4"
          aria-label={`Wyślij e-mail: ${siteConfig.email}`}
        >
          <span class="border-border bg-surface text-text-muted group-hover:border-primary group-hover:text-primary flex h-10 w-10 shrink-0 items-center justify-center rounded-full border transition-colors duration-200">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2"></rect>
              <path d="m22 7-10 6L2 7"></path>
            </svg>
          </span>
          <div>
            <p class="text-label tracking-label text-text-muted font-medium uppercase">E-mail</p>
            <p class="text-text group-hover:text-primary mt-0.5 text-sm font-medium transition-colors duration-200">{siteConfig.email}</p>
          </div>
        </a>

        <!-- Adres -->
        <a
          href={mapsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-start gap-4"
          aria-label={`Otwórz mapę: ${fullAddress}`}
        >
          <span class="border-border bg-surface text-text-muted group-hover:border-primary group-hover:text-primary flex h-10 w-10 shrink-0 items-center justify-center rounded-full border transition-colors duration-200">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
              <path d="M20 10c0 7-8 13-8 13s-8-6-8-13a8 8 0 0 1 16 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
          </span>
          <div>
            <p class="text-label tracking-label text-text-muted font-medium uppercase">Adres</p>
            <p class="text-text group-hover:text-primary mt-0.5 text-sm font-medium leading-relaxed transition-colors duration-200">
              {siteConfig.address.street}<br />{siteConfig.address.zip} {siteConfig.address.city}
            </p>
          </div>
        </a>

        <!-- Godziny -->
        <div class="flex items-start gap-4">
          <span class="border-border bg-surface text-text-muted flex h-10 w-10 shrink-0 items-center justify-center rounded-full border">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
          </span>
          <div>
            <p class="text-label tracking-label text-text-muted font-medium uppercase">Godziny kontaktu</p>
            <div class="text-text mt-0.5 text-sm font-medium leading-relaxed">
              {siteConfig.openingHours.map((spec) => (
                <span class="block">{formatDays(spec.days)}: {spec.opens}&ndash;{spec.closes}</span>
              ))}
            </div>
          </div>
        </div>

        <!-- Google Wizytówka -->
        <div class="border-border mt-2 border-t pt-6">
          <a
            href={siteConfig.social.google}
            target="_blank"
            rel="noopener noreferrer"
            class="group border-border hover:border-primary bg-surface inline-flex w-full items-center gap-4 rounded-xl border px-5 py-4 transition-[border-color,box-shadow] duration-200 hover:shadow-[0_8px_24px_-8px_var(--glow-action)]"
            aria-label="Otwórz profil RoomWork na Google"
          >
            <svg
              viewBox="0 0 24 24"
              class="h-6 w-6 shrink-0"
              aria-hidden="true"
            >
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            <div class="min-w-0 flex-1">
              <p class="text-label tracking-label text-text-muted font-medium uppercase">Google Wizytówka</p>
              <p class="text-text group-hover:text-primary mt-0.5 text-sm font-medium transition-colors duration-200">
                Opinie i szczegóły na Google
              </p>
            </div>
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-text-muted group-hover:text-primary h-4 w-4 shrink-0 transition-colors duration-200"
              aria-hidden="true"
            >
              <path d="M7 17 17 7"></path>
              <path d="M7 7h10v10"></path>
            </svg>
          </a>
        </div>

      </div>
    </div>
  </div>
</section>
