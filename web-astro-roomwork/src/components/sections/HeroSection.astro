---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { siteConfig } from '../../data/siteConfig';

type FeatureIcon = 'shield' | 'document' | 'location' | 'phone' | 'mail' | 'clock';

interface Feature {
  icon: FeatureIcon;
  label: string;
}

interface Props {
  image: ImageMetadata;
  alt: string;
  eyebrow: string;
  eyebrow2?: string;
  title: string;
  /** Fragment tytułu do wyróżnienia zielonym podkreśleniem */
  titleHighlight?: string;
  subtitle: string;
  features?: Feature[];
  ctaPrimary?: { label: string; href: string };
}

const ICONS: Record<FeatureIcon, string> = {
  shield:
    '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"></path>',
  document:
    '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7z"></path><path d="M14 2v5h5"></path><path d="M16 13H8"></path><path d="M16 17H8"></path><path d="M10 9H8"></path>',
  location:
    '<path d="M20 10c0 7-8 13-8 13S4 17 4 10a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle>',
  phone:
    '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>',
  mail: '<rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>',
  clock:
    '<circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline>',
};

const DEFAULT_FEATURES: Feature[] = [
  { icon: 'shield', label: 'Pełne wyposażenie' },
  { icon: 'document', label: 'Faktura VAT' },
  { icon: 'location', label: 'Parking na miejscu' },
];

const DEFAULT_CTA_PRIMARY = { label: 'Sprawdź kwatery', href: '/kwatery' };

const {
  image,
  alt,
  eyebrow,
  eyebrow2,
  title,
  titleHighlight,
  subtitle,
  features = DEFAULT_FEATURES,
  ctaPrimary = DEFAULT_CTA_PRIMARY,
} = Astro.props;

const { phone: phoneRaw, phoneFormatted } = siteConfig;

const titleParts = titleHighlight ? title.split(titleHighlight) : null;
const hasHighlight = titleParts !== null && titleParts.length === 2;
---

<section aria-labelledby="hero-heading" class="bg-background relative overflow-hidden">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,var(--glow-primary),transparent_55%),radial-gradient(ellipse_at_bottom_left,var(--glow-primary-soft),transparent_50%)]"
  >
  </div>

  <div
    class="relative mx-auto grid max-w-7xl gap-12 px-4 py-14 sm:px-6 md:gap-10 md:py-20 lg:grid-cols-12 lg:gap-16 lg:px-8 lg:py-28"
  >
    <div class="flex min-w-0 flex-col justify-center lg:col-span-7">
      <div class="flex flex-wrap gap-2">
        <span
          class="border-border bg-surface text-primary inline-flex w-fit items-center gap-2 rounded-full border px-3 py-1 text-xs font-medium tracking-wider uppercase"
        >
          <span aria-hidden="true" class="bg-primary h-1.5 w-1.5 rounded-full"></span>
          {eyebrow}
        </span>
        {eyebrow2 && (
          <span
            class="bg-surface inline-flex w-fit items-center gap-2 rounded-full border border-blue-200 px-3 py-1 text-xs font-medium tracking-wider text-blue-600 uppercase dark:border-blue-800 dark:text-blue-400"
          >
            <span aria-hidden="true" class="h-1.5 w-1.5 rounded-full bg-blue-600 dark:bg-blue-400"
            ></span>
            {eyebrow2}
          </span>
        )}
      </div>

      {hasHighlight ? (
        <h1
          id="hero-heading"
          class="font-heading text-text text-display leading-display tracking-display mt-5 font-bold wrap-break-word lg:mt-7"
        >
          {titleParts![0]}<span class="relative inline-block">
            <span class="relative z-10">{titleHighlight}</span>
            <span
              aria-hidden="true"
              class="bg-primary/25 absolute inset-x-0 bottom-1 z-0 h-3 sm:bottom-2 sm:h-4"
            ></span>
          </span>{titleParts![1]}
        </h1>
      ) : (
        <h1
          id="hero-heading"
          class="font-heading text-text text-display leading-display tracking-display mt-5 font-bold wrap-break-word lg:mt-7"
        >
          {title}
        </h1>
      )}

      <p class="text-text-muted mt-5 max-w-xl text-base leading-relaxed sm:text-lg lg:mt-7">
        {subtitle}
      </p>

      <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:items-center lg:mt-9">
        <a
          href={ctaPrimary.href}
          class="group bg-primary text-on-primary hover:bg-secondary focus-visible:ring-primary focus-visible:ring-offset-background inline-flex items-center justify-center gap-2 rounded-full px-6 py-3.5 text-sm font-semibold transition-[background-color,box-shadow,transform] duration-200 ease-out hover:-translate-y-px hover:shadow-[0_14px_28px_-12px_var(--glow-action)] focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-none"
        >
          <span>{ctaPrimary.label}</span>
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-4 w-4 transition-transform duration-200 ease-out group-hover:translate-x-0.5"
            aria-hidden="true"
          >
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>

        <a
          href={`tel:${phoneRaw}`}
          class="border-border bg-surface text-text hover:border-primary hover:text-primary focus-visible:ring-primary focus-visible:ring-offset-background inline-flex items-center justify-center gap-2 rounded-full border px-6 py-3.5 text-sm font-semibold transition-colors duration-200 ease-out focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-none"
          aria-label={`Zadzwoń pod numer ${phoneFormatted}`}
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-4 w-4"
            aria-hidden="true"
          >
            <path
              d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
            ></path>
          </svg>
          <span>Zadzwoń {phoneFormatted}</span>
        </a>
      </div>

      <ul
        class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-3 lg:mt-10"
        aria-label="Cechy oferty"
      >
        {features.map((feature) => (
          <li class="text-text inline-flex items-center gap-2 text-sm font-medium">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-primary h-4.5 w-4.5 shrink-0"
              aria-hidden="true"
              set:html={ICONS[feature.icon]}
            />
            <span>{feature.label}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="relative min-w-0 lg:col-span-5">
      <div
        aria-hidden="true"
        class="border-primary/30 bg-primary/5 absolute -bottom-3 -left-3 hidden h-2/3 w-2/3 rounded-3xl border sm:block lg:-bottom-4 lg:-left-4"
      >
      </div>
      <div
        aria-hidden="true"
        class="bg-secondary/15 absolute -top-3 -right-2 hidden h-24 w-24 rounded-full blur-2xl sm:block lg:-top-4 lg:-right-4 lg:h-32 lg:w-32"
      >
      </div>

      <div
        class="ring-border relative aspect-[3/2] overflow-hidden rounded-3xl shadow-[0_30px_60px_-30px_var(--glow-card)] ring-1"
      >
        <Image
          src={image}
          alt={alt}
          widths={[480, 768, 1024, 1280]}
          sizes="(min-width: 1024px) 40vw, (min-width: 640px) 80vw, 100vw"
          loading="eager"
          fetchpriority="high"
          class="absolute inset-0 h-full w-full object-cover object-center"
        />
      </div>
    </div>
  </div>
</section>
