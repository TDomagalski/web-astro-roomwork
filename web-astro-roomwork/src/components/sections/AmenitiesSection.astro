---
const amenities = [
  {
    title: 'Prywatne łazienki',
    description: 'Każdy pokój z własną, osobną łazienką.',
    icon: '<path d="M4 12h16M4 6h16M4 18h7"></path><path d="M15 18a3 3 0 0 0 6 0v-3h-6v3z"></path><path d="M15 9V6a3 3 0 0 0-6 0v6"></path>',
  },
  {
    title: 'Bezpłatny parking',
    description: 'Parking na terenie obiektu — auta, busy, ciężarówki.',
    icon: '<rect x="1" y="3" width="15" height="13" rx="2"></rect><path d="M16 8h4l3 3v5h-7V8z"></path><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle>',
  },
  {
    title: 'Szybkie WiFi',
    description: 'Internet dostępny w całym obiekcie bez limitu.',
    icon: '<path d="M5 12.55a11 11 0 0 1 14.08 0"></path><path d="M1.42 9a16 16 0 0 1 21.16 0"></path><path d="M8.53 16.11a6 6 0 0 1 6.95 0"></path><line x1="12" y1="20" x2="12.01" y2="20"></line>',
  },
  {
    title: 'Wyposażona kuchnia',
    description: 'W pełni wyposażona kuchnia wspólna dla wszystkich gości.',
    icon: '<path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"></path><path d="M7 2v20"></path><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"></path>',
  },
  {
    title: 'Pralnia',
    description: 'Pralnia do dyspozycji gości przez cały tydzień.',
    icon: '<rect x="2" y="2" width="20" height="20" rx="2" ry="2"></rect><path d="M12 18a6 6 0 1 0 0-12 6 6 0 0 0 0 12z"></path><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line>',
  },
  {
    title: 'Telewizja',
    description: 'TV z dostępem do kanałów w każdym pokoju.',
    icon: '<rect x="2" y="7" width="20" height="15" rx="2" ry="2"></rect><polyline points="17 2 12 7 7 2"></polyline>',
  },
  {
    title: 'Faktura VAT',
    description: 'Wystawiamy fakturę VAT — niezbędną dla firm i działów HR.',
    icon: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline>',
  },
  {
    title: 'Kontakt całą dobę',
    description: 'Bezpośredni kontakt z właścicielem przez całą dobę.',
    icon: '<circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline>',
  },
] as const;
---

<section aria-labelledby="amenities-heading" class="bg-background py-16 lg:py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">

    <div class="mb-12 lg:mb-16">
      <span class="border-border bg-surface text-primary inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-medium tracking-wider uppercase">
        <span aria-hidden="true" class="bg-primary h-1.5 w-1.5 rounded-full"></span>
        Wyposażenie i udogodnienia
      </span>
      <h2 id="amenities-heading" class="font-heading text-text mt-5 text-headline leading-headline font-bold">
        Wszystko czego potrzebuje Twoja ekipa
      </h2>
      <p class="text-text-muted mt-3 max-w-xl text-base leading-body">
        Zadbaliśmy o każdy detal, żeby Twoi pracownicy mogli odpocząć po ciężkim dniu. Pełne wyposażenie bez ukrytych kosztów.
      </p>
    </div>

    <ul class="grid grid-cols-2 gap-4 md:grid-cols-3 xl:grid-cols-4" aria-label="Lista udogodnień">
      {amenities.map((item) => (
        <li class="border-border bg-surface group flex flex-col gap-4 rounded-2xl border p-5 transition-[border-color,box-shadow] duration-200 hover:border-primary hover:shadow-[0_8px_24px_-8px_var(--glow-action)]">
          <div class="bg-primary/10 flex h-10 w-10 shrink-0 items-center justify-center rounded-full">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-primary h-5 w-5"
              aria-hidden="true"
              set:html={item.icon}
            />
          </div>
          <div>
            <p class="text-text text-sm font-semibold">{item.title}</p>
            <p class="text-text-muted mt-1 text-xs leading-body">{item.description}</p>
          </div>
        </li>
      ))}
    </ul>

  </div>
</section>
