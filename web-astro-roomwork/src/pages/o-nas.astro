---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import { siteConfig } from '../data/siteConfig';
import heroImage from '../assets/hero_section-roomwork.webp';

const phoneFormatted = '690 328 659';
const phoneRaw = siteConfig.phone;

const timeline = [
  {
    year: '2015',
    title: 'Założenie firmy',
    description: 'Family Party Sp. z o.o. rozpoczyna działalność jako organizator imprez okolicznościowych i eventów firmowych w regionie Małopolski.',
  },
  {
    year: '2018',
    title: 'Rozwój działalności eventowej',
    description: 'Obsługa kilkudziesięciu eventów rocznie — przyjęcia firmowe, uroczystości, eventy integracyjne. Budowanie sieci kontaktów z firmami regionu.',
  },
  {
    year: '2022',
    title: 'Otwarcie RoomWork',
    description: 'Dostrzegając rosnące zapotrzebowanie na solidne kwatery pracownicze w okolicach Krakowa, spółka otwiera obiekt RoomWork przy ul. Krakowskiej 62d w Słomnikach.',
  },
] as const;

const values = [
  {
    title: 'Rzetelność',
    description: 'Dotrzymujemy warunków i terminów. Firmy, które do nas wracają, wiedzą, że nie ma niespodzianek — ceny, standardy i zasady są transparentne od pierwszej rozmowy.',
    icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"></path>',
  },
  {
    title: 'Elastyczność',
    description: 'Rozumiemy specyfikę pracy sezonowej i kontraktowej. Przyjmujemy grupy na tydzień, miesiąc lub kilka miesięcy — i potrafimy dostosować się do zmiennych harmonogramów.',
    icon: '<path d="M18 8h1a4 4 0 0 1 0 8h-1"></path><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"></path><line x1="6" y1="1" x2="6" y2="4"></line><line x1="10" y1="1" x2="10" y2="4"></line><line x1="14" y1="1" x2="14" y2="4"></line>',
  },
  {
    title: 'Bezpośredni kontakt',
    description: 'Rozmawiasz z właścicielem, nie call center. Decyzje zapadają od razu — bez przekierowań, bez czekania na e-mail. To doceniają kierownicy budów i działy HR.',
    icon: '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>',
  },
] as const;
---

<BaseLayout
  title="O nas — Family Party Sp. z o.o. | RoomWork Słomniki"
  description="Poznaj historię RoomWork. Family Party Sp. z o.o. — lokalna firma z Małopolski, od eventów do kwater pracowniczych w Słomnikach k. Krakowa."
>
  <HeroSection
    image={heroImage}
    alt="Obiekt RoomWork — kwatery pracownicze w Słomnikach, ul. Krakowska 62d"
    eyebrow="O nas · Family Party Sp. z o.o."
    eyebrow2="Słomniki · Małopolska"
    title="Poznaj nas — ludzi stojących za RoomWork"
    titleHighlight="ludzi stojących za RoomWork"
    subtitle="Jesteśmy lokalną firmą z wieloletnim doświadczeniem w obsłudze grup i organizacji zakwaterowania. Poznaj naszą historię i wartości."
    features={[
      { icon: 'shield', label: 'Lokalna firma' },
      { icon: 'document', label: 'Spółka z o.o.' },
      { icon: 'location', label: 'Słomniki k. Krakowa' },
    ]}
    ctaPrimary={{ label: 'Skontaktuj się z nami', href: '/kontakt' }}
  />

  <!-- Sekcja 1: Historia -->
  <section aria-labelledby="history-heading" class="bg-surface py-16 lg:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-start lg:gap-16">

        <div>
          <span class="border-border bg-background text-primary inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-medium tracking-wider uppercase">
            <span aria-hidden="true" class="bg-primary h-1.5 w-1.5 rounded-full"></span>
            Nasza historia
          </span>
          <h2 id="history-heading" class="font-heading text-text mt-5 text-headline leading-headline font-bold">
            Od organizacji eventów do kwater pracowniczych
          </h2>
          <div class="mt-6 flex flex-col gap-4">
            <p class="text-text-muted text-base leading-body">
              Family Party Sp. z o.o. powstała z pasji do organizacji — przyjęć, eventów firmowych i uroczystości okolicznościowych. Przez lata budowaliśmy relacje z firmami i przedsiębiorcami z regionu Małopolski, rozumiejąc ich potrzeby i rytm pracy. [PLACEHOLDER — uzupełnij historią firmy]
            </p>
            <p class="text-text-muted text-base leading-body">
              Z biegiem czasu dostrzegliśmy rosnącą potrzebę rynku — firmy budowlane i remontowe, pracownicy delegowani, ekipy sezonowe potrzebowały solidnego, sprawdzonego miejsca noclegowego w okolicach Krakowa. Tak narodził się pomysł na RoomWork. [PLACEHOLDER — uzupełnij]
            </p>
            <p class="text-text-muted text-base leading-body">
              Dziś przy ul. Krakowskiej 62d w Słomnikach prowadzimy nowoczesny obiekt z 10 pokojami i 40 miejscami noclegowymi. Każdy pokój z własną łazienką, parking, WiFi, kuchnia i pralnia — wszystko, czego potrzebuje pracująca ekipa. [PLACEHOLDER — uzupełnij]
            </p>
          </div>
        </div>

        <!-- Timeline -->
        <div class="flex flex-col pt-2 lg:pt-14">
          {timeline.map((item, i) => (
            <div class="relative flex gap-6 pb-8 last:pb-0">
              <div class="flex flex-col items-center">
                <div class="bg-primary text-on-primary flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-xs font-bold tabular-nums">
                  {item.year}
                </div>
                {i < timeline.length - 1 && (
                  <div class="bg-border mt-2 w-px flex-1"></div>
                )}
              </div>
              <div class="pb-2 pt-1.5">
                <p class="text-text text-sm font-semibold">{item.title}</p>
                <p class="text-text-muted mt-1 text-sm leading-body">{item.description}</p>
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- Sekcja 2: Czym się zajmujemy -->
  <section aria-labelledby="activity-heading" class="bg-background py-16 lg:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <span class="border-border bg-surface text-primary inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-medium tracking-wider uppercase">
          <span aria-hidden="true" class="bg-primary h-1.5 w-1.5 rounded-full"></span>
          Nasza działalność
        </span>
        <h2 id="activity-heading" class="font-heading text-text mt-5 text-headline leading-headline font-bold">
          Kwatery pracownicze w sercu Małopolski
        </h2>
      </div>

      <div class="grid gap-6 sm:grid-cols-3">
        {[
          {
            label: '10 pokoi, 40 miejsc',
            desc: 'Przyjmujemy zarówno małe zespoły, jak i duże ekipy do 40 osób jednocześnie.',
            icon: '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline>',
          },
          {
            label: 'Własne łazienki',
            desc: 'Każdy pokój z prywatną łazienką — komfort niezależny od liczby gości.',
            icon: '<path d="M4 12h16M4 6h16M4 18h7"></path><path d="M15 18a3 3 0 0 0 6 0v-3h-6v3z"></path>',
          },
          {
            label: 'Elastyczne warunki',
            desc: 'Pobyty tygodniowe, miesięczne i wielomiesięczne. Faktura VAT w standardzie.',
            icon: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7z"></path><polyline points="14 2 14 8 20 8"></polyline>',
          },
        ].map((card) => (
          <div class="border-border bg-surface flex flex-col gap-4 rounded-2xl border p-6">
            <div class="bg-primary/10 flex h-11 w-11 items-center justify-center rounded-full">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="text-primary h-5 w-5" aria-hidden="true" set:html={card.icon} />
            </div>
            <div>
              <p class="text-text font-semibold">{card.label}</p>
              <p class="text-text-muted mt-1 text-sm leading-body">{card.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <p class="text-text-muted mt-10 max-w-3xl text-base leading-body">
        RoomWork to kwatery pracownicze w Słomnikach (ul. Krakowska 62d), położone przy trasie E7 łączącej Kraków z Kielcami. Obsługujemy ekipy budowlane, pracowników delegowanych i sezonowych oraz grupy korporacyjne z całej Małopolski — w tym z Krakowa, Miechowa, Proszowic i okolicznych miejscowości. [PLACEHOLDER — uzupełnij o szczegóły oferty]
      </p>
    </div>
  </section>

  <!-- Sekcja 3: Wartości -->
  <section aria-labelledby="values-heading" class="bg-surface py-16 lg:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 text-center">
        <span class="border-border bg-background text-primary inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-medium tracking-wider uppercase">
          <span aria-hidden="true" class="bg-primary h-1.5 w-1.5 rounded-full"></span>
          Nasze wartości
        </span>
        <h2 id="values-heading" class="font-heading text-text mt-5 text-headline leading-headline font-bold">
          Dlaczego firmy wracają do RoomWork
        </h2>
      </div>

      <div class="grid gap-6 sm:grid-cols-3">
        {values.map((value) => (
          <div class="border-border bg-background flex flex-col gap-4 rounded-2xl border p-6">
            <div class="bg-primary/10 flex h-11 w-11 items-center justify-center rounded-full">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="text-primary h-5 w-5" aria-hidden="true" set:html={value.icon} />
            </div>
            <div>
              <p class="text-text text-title font-semibold">{value.title}</p>
              <p class="text-text-muted mt-2 text-sm leading-body">{value.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Sekcja 4: Dane spółki -->
  <section aria-labelledby="company-heading" class="bg-background py-16 lg:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-10 lg:grid-cols-2 lg:items-start lg:gap-16">

        <div>
          <span class="border-border bg-surface text-primary inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-medium tracking-wider uppercase">
            <span aria-hidden="true" class="bg-primary h-1.5 w-1.5 rounded-full"></span>
            Dane rejestrowe
          </span>
          <h2 id="company-heading" class="font-heading text-text mt-5 text-headline leading-headline font-bold">
            Family Party Sp. z o.o.
          </h2>
          <dl class="mt-6 flex flex-col gap-3">
            {[
              { label: 'Pełna nazwa', value: 'Family Party Spółka z ograniczoną odpowiedzialnością' },
              { label: 'Adres', value: 'ul. Krakowska 62d, 32-090 Słomniki' },
              { label: 'NIP', value: '6821777738' },
              { label: 'REGON', value: '381101585' },
              { label: 'KRS', value: '[PLACEHOLDER]' },
            ].map((row) => (
              <div class="border-border flex flex-col gap-0.5 border-b pb-3 last:border-0">
                <dt class="text-label tracking-label text-text-muted font-medium uppercase">{row.label}</dt>
                <dd class="text-text text-sm font-medium">{row.value}</dd>
              </div>
            ))}
          </dl>
        </div>

        <div class="border-border bg-surface flex flex-col gap-5 rounded-2xl border p-8 lg:mt-14">
          <div class="bg-primary/10 flex h-11 w-11 items-center justify-center rounded-full">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="text-primary h-5 w-5" aria-hidden="true">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
            </svg>
          </div>
          <div>
            <p class="text-text font-semibold">Masz pytanie do nas?</p>
            <p class="text-text-muted mt-2 text-sm leading-body">
              Chętnie odpowiemy na pytania dotyczące spółki, oferty lub warunków współpracy. Napisz lub zadzwoń — odpowiadamy bez zbędnej zwłoki.
            </p>
          </div>
          <a
            href="/kontakt"
            class="bg-primary text-on-primary hover:bg-secondary inline-flex w-fit items-center gap-2 rounded-full px-5 py-2.5 text-sm font-semibold transition-colors duration-200"
          >
            Przejdź do kontaktu
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5" aria-hidden="true">
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- Sekcja 5: CTA końcowe -->
  <section aria-labelledby="cta-anas-heading" class="bg-elevated py-16 lg:py-24">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <span class="border-on-elevated/20 text-on-elevated/70 inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-medium tracking-wider uppercase">
        <span aria-hidden="true" class="bg-primary h-1.5 w-1.5 rounded-full"></span>
        Rezerwacja
      </span>
      <h2 id="cta-anas-heading" class="font-heading text-on-elevated mt-5 text-headline leading-headline font-bold">
        Potrzebujesz kwater dla swojej ekipy?
      </h2>
      <p class="text-on-elevated/70 mt-4 text-base leading-body">
        Zadzwoń lub napisz — dobierzemy wolne miejsca do Twoich potrzeb. Pobyty krótko- i długoterminowe, faktura VAT, bezpośredni kontakt z właścicielem.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href={`tel:${phoneRaw}`}
          class="bg-primary text-on-primary hover:bg-secondary inline-flex items-center gap-2 rounded-full px-6 py-3.5 text-sm font-semibold transition-[background-color,transform] duration-200 hover:-translate-y-px hover:shadow-[0_14px_28px_-12px_var(--glow-action)]"
          aria-label={`Zadzwoń pod numer ${phoneFormatted}`}
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
          </svg>
          Zadzwoń teraz — {phoneFormatted}
        </a>
        <a
          href={`mailto:${siteConfig.email}`}
          class="border-on-elevated/25 text-on-elevated hover:border-primary hover:text-primary inline-flex items-center gap-2 rounded-full border px-6 py-3.5 text-sm font-semibold transition-colors duration-200"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
            <rect x="2" y="4" width="20" height="16" rx="2"></rect>
            <path d="m22 7-10 6L2 7"></path>
          </svg>
          Napisz do nas
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
