---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/siteConfig';

const { phone: phoneRaw, phoneFormatted } = siteConfig;
---

<BaseLayout
  title="Regulamin — RoomWork Słomniki"
  description="Regulamin korzystania z kwater pracowniczych RoomWork w Słomnikach. Zasady pobytu, prawa i obowiązki Gości oraz Właściciela obiektu."
  ogImage="/og-images/og-roomwork.webp"
>
  <!-- Nagłówek dokumentu -->
  <div class="bg-elevated relative overflow-hidden">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,var(--glow-primary-soft),transparent_60%)]"
    >
    </div>

    <div class="relative mx-auto max-w-3xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
      <h1 class="font-heading text-on-elevated text-headline leading-headline font-bold">
        Regulamin obiektu RoomWork
      </h1>
      <p class="text-on-elevated/60 mt-3 max-w-xl text-sm leading-relaxed">
        Niniejszy regulamin określa zasady korzystania z kwater pracowniczych RoomWork prowadzonych
        przez Family Party Sp.&nbsp;z&nbsp;o.o. Prosimy o zapoznanie się z jego treścią przed
        podjęciem pobytu.
      </p>

      <div class="border-on-elevated/15 mt-8 flex flex-wrap items-center gap-3 border-t pt-6 pb-2">
        <span
          class="border-primary/30 text-on-elevated/80 rounded-full border px-3 py-1 text-xs font-medium"
        >
          Obowiązuje od: 1&nbsp;stycznia 2022
        </span>
        <span class="text-on-elevated/30 text-xs">·</span>
        <span class="text-on-elevated/50 text-xs">Family Party Sp. z o.o.</span>
        <span class="text-on-elevated/30 text-xs">·</span>
        <span class="text-on-elevated/50 text-xs">ul. Krakowska 62d, Słomniki</span>
      </div>
    </div>
  </div>

  <!-- Treść dokumentu -->
  <div class="bg-background py-16 lg:py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">

      <div class="border-border bg-surface rounded-2xl border p-8 sm:p-12">
        <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-xl bg-primary/10">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="text-primary h-7 w-7"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"
            ></path>
          </svg>
        </div>

        <h2 class="font-heading text-text text-xl font-bold sm:text-2xl">
          Regulamin dostępny na miejscu
        </h2>

        <p class="text-text-muted leading-body mt-4 text-sm sm:text-base">
          Pełna treść regulaminu korzystania z kwater pracowniczych RoomWork jest dostępna
          do wglądu bezpośrednio w obiekcie — przy zameldowaniu lub na każde życzenie Gościa
          w trakcie pobytu.
        </p>

        <p class="text-text-muted leading-body mt-3 text-sm sm:text-base">
          Zapoznanie się z regulaminem i jego akceptacja następuje przy pierwszym zameldowaniu.
          Dokument jest prowadzony przez
          <strong class="text-text font-semibold">Family Party Sp.&nbsp;z&nbsp;o.o.</strong>
          i może być udostępniony na prośbę Gościa w dowolnym momencie pobytu.
        </p>

        <div class="border-border mt-8 border-t pt-7">
          <p class="text-text-muted text-sm">
            Pytania dotyczące zasad pobytu? Skontaktuj się z nami:
          </p>
          <a
            href={`tel:${phoneRaw}`}
            class="text-primary mt-2 inline-flex items-center gap-2 text-sm font-semibold transition-opacity hover:opacity-75"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75Z"
              ></path>
            </svg>
            {phoneFormatted}
          </a>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>
