---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import ContactSection from '../components/pages/kontakt/ContactSection.astro';
import heroImage from '../assets/hero_section-kontakt.webp';
---

<BaseLayout
  title="Kontakt — RoomWork Słomniki"
  description="Skontaktuj się z RoomWork. Kwatery pracownicze w Słomnikach — zadzwoń lub napisz. Odpowiadamy tego samego dnia."
>
  <HeroSection
    image={heroImage}
    alt="Kwatery pracownicze RoomWork — Słomniki, ul. Krakowska 62d"
    title="Skontaktuj się z nami"
    titleHighlight="Skontaktuj się z nami"
    subtitle="Masz pytania o kwatery lub chcesz zarezerwować miejsca dla swojej ekipy? Zadzwoń albo napisz."
    eyebrow="Kwatery pracownicze · Słomniki"
    eyebrow2="Zadzwoń lub napisz · 690 328 659"
    features={[
      { icon: 'phone', label: 'Zadzwoń — odbieramy' },
      { icon: 'mail', label: 'Napisz — odpowiadamy' },
    ]}
  />
  <ContactSection />
</BaseLayout>
