---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import KwaterySection from '../components/islands/KwaterySection';
import heroImage from '../assets/hero_section-kwatery.webp';
---

<BaseLayout
  title="Kwatery pracownicze — 11 pokoi w Słomnikach | RoomWork"
  description="Kwatery pracownicze w Słomnikach k. Krakowa — 11 pokoi, do 40 osób, własne łazienki, parking, Wi-Fi, faktura VAT. Przy trasie E7. Dzwoń i rezerwuj."
  ogImage="/og-images/og-kwatery.webp"
>
  <HeroSection
    image={heroImage}
    alt="Kwatery pracownicze RoomWork — budynek przy ul. Krakowskiej 62d w Słomnikach"
    eyebrow="Kwatery pracownicze · Słomniki"
    eyebrow2="11 pokoi · do 40 osób"
    title="Kwatery pracownicze — 11 pokoi w Słomnikach"
    titleHighlight="11 pokoi w Słomnikach"
    subtitle="Własne łazienki, w pełni wyposażona kuchnia, bezpłatny parking i szybkie Wi-Fi. Obiekt przy trasie E7 — dojazd do Krakowa, Miechowa i Proszowic. Faktura VAT dla każdej firmy."
    ctaPrimary={{ label: 'Zapytaj o nocleg', href: '/kontakt' }}
    features={[
      { icon: 'shield', label: 'Pełne wyposażenie' },
      { icon: 'document', label: 'Faktura VAT' },
      { icon: 'location', label: 'Parking na miejscu' },
    ]}
  />
  <KwaterySection client:load />
</BaseLayout>
