---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import AmenitiesSection from '../components/sections/AmenitiesSection.astro';
import ForWhoSection from '../components/sections/ForWhoSection.astro';
import LocationSection from '../components/sections/LocationSection.astro';
import FaqSection from '../components/sections/FaqSection.astro';
import heroImage from '../assets/hero_section-roomwork.webp';
---

<BaseLayout
  title="Kwatery pracownicze Słomniki k. Krakowa — RoomWork"
  description="Kwatery pracownicze w Słomnikach k. Krakowa. 10 pokoi, 40 miejsc, prywatne łazienki, parking, WiFi, faktura VAT. Dla ekip budowlanych i firm."
>
  <HeroSection
    image={heroImage}
    alt="Kwatery pracownicze RoomWork — Słomniki k. Krakowa"
    eyebrow="Kwatery pracownicze · Słomniki k. Krakowa"
    eyebrow2="10 pokoi · 40 miejsc · Faktura VAT"
    title="Kwatery pracownicze dla Twojej ekipy"
    titleHighlight="dla Twojej ekipy"
    subtitle="Komfortowe zakwaterowanie dla ekip budowlanych, pracowników delegowanych i firm w Słomnikach k. Krakowa. Własne łazienki, parking, WiFi, faktura VAT."
    features={[
      { icon: 'shield', label: 'Pełne wyposażenie' },
      { icon: 'document', label: 'Faktura VAT' },
      { icon: 'location', label: 'Parking na miejscu' },
    ]}
    ctaPrimary={{ label: 'Sprawdź kwatery', href: '/kwatery' }}
  />
  <AmenitiesSection />
  <ForWhoSection />
  <LocationSection />
  <FaqSection />
</BaseLayout>
