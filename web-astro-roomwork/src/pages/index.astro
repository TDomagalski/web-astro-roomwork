---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import AmenitiesSection from '../components/pages/home/AmenitiesSection.astro';
import ForWhoSection from '../components/pages/home/ForWhoSection.astro';
import LocationSection from '../components/pages/home/LocationSection.astro';
import FaqSection from '../components/pages/home/FaqSection.astro';
import heroImage from '../assets/hero_section-roomwork.webp';
---

<BaseLayout
  title="Kwatery pracownicze Słomniki k. Krakowa — RoomWork"
  description="Kwatery pracownicze w Słomnikach k. Krakowa. 11 pokoi, 40 miejsc, prywatne łazienki, parking, WiFi, faktura VAT. Dla ekip budowlanych i firm."
  ogImage="/og-images/og-roomwork.webp"
>
  <HeroSection
    image={heroImage}
    alt="Kwatery pracownicze RoomWork — Słomniki k. Krakowa"
    eyebrow="Kwatery pracownicze · Słomniki k. Krakowa"
    eyebrow2="11 pokoi · 40 miejsc · Faktura VAT"
    title="Noclegi pracownicze przy trasie E7 — blisko Krakowa"
    titleHighlight="blisko Krakowa"
    subtitle="Spokojny nocleg blisko Krakowa, bez pośredników i niespodzianek. Elastyczne warunki dla ekip na tygodnie lub miesiące — rozmawiasz bezpośrednio z właścicielem."
    features={[
      { icon: 'shield', label: 'Pełne wyposażenie' },
      { icon: 'document', label: 'Faktura VAT' },
      { icon: 'location', label: 'Parking na miejscu' },
    ]}
    ctaPrimary={{ label: 'Sprawdź kwatery', href: '/kwatery' }}
  />
  <AmenitiesSection />
  <ForWhoSection />
  <LocationSection />
  <FaqSection />
</BaseLayout>
